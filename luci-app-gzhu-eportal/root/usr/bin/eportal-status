#!/bin/sh

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

add_account() {
	section=$1
	config_get enabled "$section" enabled 0
	config_get label "$section" label "$section"
	config_get interface "$section" interface ''

	timestamp=0
	state='never'
	code=''
	message='尚未运行'
	status_file="/tmp/eportal-login-$section.status"
	if [ -r "$status_file" ]; then
		IFS='|' read -r timestamp state code message < "$status_file"
	fi

	case "$timestamp" in
		''|*[!0-9]*) timestamp=0 ;;
	esac

	json_add_object
	json_add_string section "$section"
	json_add_string label "$label"
	json_add_string interface "$interface"
	json_add_boolean enabled "$enabled"
	json_add_int timestamp "$timestamp"
	json_add_string state "$state"
	json_add_string code "$code"
	json_add_string message "$message"
	json_close_object
}

json_init
json_add_array accounts
config_load eportal
config_foreach add_account account
json_close_array
json_dump

config globals 'globals'
	option check_url 'http://connectivitycheck.gstatic.com/generate_204'
	option expected_code '204'
	option check_interval '120'
	option detect_timeout '15'
	option login_timeout '20'
	option verify_delay '2'
	option retry_count '1'
	option login_path 'InterFace.do?method=login'
	option rule_priority '100'

config account 'wan'
	option enabled '0'
	option label 'WAN'
	option interface 'wan'
	option username 'YOUR_ACCOUNT_A'
	option password 'YOUR_PASSWORD_A'

config account 'wan2'
	option enabled '0'
	option label 'WAN2'
	option interface 'lan1'
	option username 'YOUR_ACCOUNT_B_OR_ACCOUNT_A'
	option password 'YOUR_PASSWORD_B_OR_PASSWORD_A'
